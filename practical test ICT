<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MindTrack - AI Productivity</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
        .animate-fade-in { animation: fadeIn 0.4s ease-out forwards; }
    </style>
</head>
<body class="h-[100dvh] flex flex-col bg-slate-50 text-slate-800 overflow-hidden">

    <header class="bg-white shadow-sm flex-none z-10 border-b border-slate-100">
        <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-center gap-2">
            <h1 class="text-lg font-bold bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent">
                MindTrack
            </h1>
        </div>
    </header>

    <main class="flex-1 flex flex-col md:flex-row gap-3 p-3 max-w-6xl mx-auto w-full min-h-0">
        
        <!-- Mood Detector Section -->
        <section class="flex-[1.2] flex flex-col min-h-0 bg-white rounded-2xl p-4 shadow-sm border border-slate-100">
            <div class="flex items-center gap-2 mb-3 flex-none">
                <span class="text-purple-500">✨</span>
                <h2 class="text-md font-semibold">Mood Detector</h2>
            </div>
            
            <div class="flex-none space-y-2">
                <textarea id="moodInput" 
                    class="w-full bg-slate-50 border border-slate-200 rounded-xl p-3 text-sm focus:ring-2 focus:ring-indigo-500 outline-none resize-none transition-all"
                    rows="2" placeholder="Ceritakan perasaanmu hari ini..."></textarea>
                <p id="errorMsg" class="text-red-500 text-xs px-1 hidden">Isi dulu perasaanmu!</p>
                <button onclick="handleGetVibe()" id="btnVibe"
                    class="w-full bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl py-2.5 font-medium flex items-center justify-center gap-2 text-sm shadow-sm transition-all active:scale-95 disabled:opacity-50">
                    Get Vibe
                </button>
            </div>

            <div id="aiContainer" class="flex-1 overflow-y-auto mt-4 custom-scrollbar min-h-0">
                <div id="aiPlaceholder" class="h-full flex flex-col items-center justify-center text-slate-300 opacity-60">
                    <p class="text-xs">Saran AI akan muncul di sini</p>
                </div>
                <div id="aiResult" class="hidden p-4 bg-indigo-50/50 border border-indigo-100 rounded-xl animate-fade-in text-sm text-slate-700">
                    <div class="font-bold text-indigo-800 mb-2">Saran Untukmu:</div>
                    <p id="suggestionText" class="whitespace-pre-wrap leading-relaxed"></p>
                </div>
            </div>
        </section>

        <!-- To-Do Section -->
        <section class="flex-1 flex flex-col min-h-0 bg-white rounded-2xl p-4 shadow-sm border border-slate-100">
            <div class="flex items-center gap-2 mb-3 flex-none">
                <span class="text-emerald-500">📝</span>
                <h2 class="text-md font-semibold">Simple To-Do</h2>
            </div>

            <form id="todoForm" class="flex gap-2 mb-3 flex-none">
                <input type="text" id="todoInput" placeholder="Tugas baru..."
                    class="flex-1 bg-slate-50 border border-slate-200 rounded-xl px-3 py-2 text-sm focus:ring-2 focus:ring-emerald-500 outline-none">
                <button type="submit" class="bg-emerald-500 hover:bg-emerald-600 text-white px-3 rounded-xl">+</button>
            </form>

            <div id="todoList" class="flex-1 overflow-y-auto space-y-2 pr-1 custom-scrollbar min-h-0">
            </div>
        </section>
    </main>

    <div class="h-1 bg-gradient-to-r from-indigo-500 via-purple-500 to-emerald-500 flex-none"></div>

    <script>
        const apiKey = ""; // API Key otomatis terdeteksi jika dijalankan di sini

        // Logic To-Do List
        const todoForm = document.getElementById('todoForm');
        const todoList = document.getElementById('todoList');
        let todos = [{ id: 1, text: "Selesaikan Project MindTrack", completed: false }];

        function renderTodos() {
            todoList.innerHTML = todos.length === 0 ? '<p class="text-center text-xs text-slate-400 py-10 italic">Tidak ada tugas.</p>' : '';
            todos.forEach(todo => {
                const div = document.createElement('div');
                div.className = `flex items-center justify-between p-3 rounded-xl border transition-all ${todo.completed ? 'bg-slate-50 opacity-60' : 'bg-white border-slate-200'}`;
                div.innerHTML = `
                    <div class="flex items-center gap-3 cursor-pointer flex-1" onclick="toggleTodo(${todo.id})">
                        <span class="w-5 h-5 rounded-full border flex items-center justify-center ${todo.completed ? 'bg-emerald-500 border-emerald-500 text-white' : 'border-slate-300'} text-[10px]">
                            ${todo.completed ? '✓' : ''}
                        </span>
                        <span class="text-sm ${todo.completed ? 'line-through text-slate-400' : 'text-slate-700'} text-left">${todo.text}</span>
                    </div>
                    <button onclick="deleteTodo(${todo.id})" class="text-slate-300 hover:text-red-500 p-1 text-xs ml-2">Hapus</button>
                `;
                todoList.appendChild(div);
            });
        }

        todoForm.onsubmit = (e) => {
            e.preventDefault();
            const input = document.getElementById('todoInput');
            if(!input.value.trim()) return;
            todos.unshift({ id: Date.now(), text: input.value, completed: false });
            input.value = '';
            renderTodos();
        };

        window.toggleTodo = (id) => {
            todos = todos.map(t => t.id === id ? {...t, completed: !t.completed} : t);
            renderTodos();
        };

        window.deleteTodo = (id) => {
            todos = todos.filter(t => t.id !== id);
            renderTodos();
        };

        // Logic AI dengan Retry/Exponential Backoff
        async function handleGetVibe() {
            const mood = document.getElementById('moodInput').value;
            const btn = document.getElementById('btnVibe');
            const aiResult = document.getElementById('aiResult');
            const aiPlaceholder = document.getElementById('aiPlaceholder');
            const errorMsg = document.getElementById('errorMsg');
            const suggestionText = document.getElementById('suggestionText');

            if (!mood.trim()) {
                errorMsg.classList.remove('hidden');
                return;
            }

            errorMsg.classList.add('hidden');
            btn.disabled = true;
            btn.innerHTML = "Berpikir...";
            aiPlaceholder.classList.add('hidden');
            aiResult.classList.add('hidden');

            // Exponential Backoff
            const retries = 5;
            const delays = [1000, 2000, 4000, 8000, 16000];

            for (let i = 0; i < retries; i++) {
                try {
                    const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            contents: [{ parts: [{ text: `User merasa: "${mood}". Berikan saran singkat, ramah, dan empatik untuk pelajar. Maksimal 3 kalimat. Bahasa Indonesia santai.` }] }]
                        })
                    });

                    if (!response.ok) throw new Error("API Error");

                    const data = await response.json();
                    const output = data.candidates?.[0]?.content?.parts?.[0]?.text;
                    
                    if (output) {
                        suggestionText.innerText = output;
                        aiResult.classList.remove('hidden');
                        btn.disabled = false;
                        btn.innerHTML = "Get Vibe";
                        return; // Berhasil, keluar dari fungsi
                    }
                } catch (err) {
                    if (i === retries - 1) {
                        alert("Gagal terhubung ke AI. Coba lagi nanti.");
                        aiPlaceholder.classList.remove('hidden');
                    }
                    await new Promise(r => setTimeout(r, delays[i]));
                }
            }

            btn.disabled = false;
            btn.innerHTML = "Get Vibe";
        }

        renderTodos();
    </script>
</body>
</html>
